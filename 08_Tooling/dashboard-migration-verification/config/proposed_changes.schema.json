{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dashboard_migration/proposed_changes.schema.json",
  "title": "Dashboard Migration Proposed Changes Manifest",
  "description": "Structured manifest for verification-only migration proposals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "changes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/proposedChange"
      }
    }
  },
  "$defs": {
    "proposedChange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "item_type",
        "source_database",
        "source_item",
        "canonical_database",
        "canonical_item",
        "current_name",
        "proposed_name",
        "migration_method",
        "rollback_method",
        "owner",
        "approval_required",
        "notes"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "rename_field",
            "merge_field",
            "archive_view",
            "archive_database",
            "merge_database",
            "rename_status_value",
            "normalize_status_vocabulary",
            "update_linked_view",
            "update_formula_dependency",
            "dependency_cleanup"
          ]
        },
        "item_type": {
          "type": "string",
          "enum": [
            "field",
            "view",
            "database",
            "status_value",
            "linked_view",
            "formula_dependency",
            "dependency"
          ]
        },
        "source_database": {
          "type": "string",
          "minLength": 1
        },
        "source_item": {
          "type": "string",
          "minLength": 1
        },
        "canonical_database": {
          "type": "string",
          "minLength": 1
        },
        "canonical_item": {
          "type": "string",
          "minLength": 1
        },
        "current_name": {
          "type": "string",
          "minLength": 1
        },
        "proposed_name": {
          "type": "string",
          "minLength": 1
        },
        "migration_method": {
          "type": "string",
          "minLength": 1
        },
        "rollback_method": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "approval_required": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "archive_view"
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "view"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "archive_database",
                  "merge_database"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "database"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "rename_status_value",
                  "normalize_status_vocabulary"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "status_value"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "update_linked_view"
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "linked_view"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "update_formula_dependency"
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "formula_dependency"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "dependency_cleanup"
              }
            }
          },
          "then": {
            "properties": {
              "item_type": {
                "const": "dependency"
              }
            }
          }
        }
      ]
    }
  }
}
