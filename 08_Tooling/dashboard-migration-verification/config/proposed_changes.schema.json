{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dashboard Migration Proposed Changes",
  "type": "object",
  "required": ["version", "changes"],
  "properties": {
    "version": { "type": "integer" },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "item_type",
          "source_database",
          "source_item",
          "canonical_database",
          "canonical_item",
          "current_name",
          "proposed_name",
          "migration_method",
          "rollback_method",
          "owner",
          "approval_required",
          "notes"
        ],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "rename_field",
              "merge_field",
              "archive_view",
              "archive_database",
              "merge_database",
              "rename_status_value",
              "normalize_status_vocabulary",
              "update_linked_view",
              "update_formula_dependency",
              "dependency_cleanup"
            ]
          },
          "item_type": { "type": "string" },
          "source_database": { "type": "string" },
          "source_item": { "type": "string" },
          "canonical_database": { "type": "string" },
          "canonical_item": { "type": "string" },
          "current_name": { "type": "string" },
          "proposed_name": { "type": "string" },
          "migration_method": { "type": "string" },
          "rollback_method": { "type": "string" },
          "owner": { "type": "string" },
          "approval_required": { "type": "boolean" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
