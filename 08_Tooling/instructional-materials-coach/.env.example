# Path to the OAuth client secret JSON downloaded from Google Cloud Console.
GOOGLE_OAUTH_CLIENT_SECRET_PATH=

# Path where the cached user OAuth token is stored after first login.
GOOGLE_OAUTH_TOKEN_PATH=

# Default template IDs (optional -- can be passed on the CLI instead).
DEFAULT_SLIDES_TEMPLATE_ID=
DEFAULT_DOC_TEMPLATE_ID=
DEFAULT_TARGET_FOLDER_ID=

# Must be explicitly set to true before any live write is attempted.
ALLOW_WRITE=false
